# =============================================
# TicketSpace Configuration
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================

# ----- Application -----
APP_NAME=TicketSpace
APP_URL=https://ticketspace.es
APP_ENV=production
APP_DEBUG=false
APP_LOCALE=es
APP_TIMEZONE=Europe/Madrid

# ----- Database -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ticketspace
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# ----- JWT Authentication -----
# Generate a strong secret: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# ----- Stripe -----
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- PayPal -----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ----- SEPA (via Stripe) -----
SEPA_ENABLED=true

# ----- Email (SMTP) -----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@ticketspace.es
SMTP_FROM_NAME=TicketSpace

# ----- Apple Wallet -----
APPLE_PASS_TYPE_ID=
APPLE_TEAM_ID=
APPLE_CERT_PATH=
APPLE_CERT_PASS=
APPLE_WWDR_CERT_PATH=

# ----- Google Wallet -----
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=

# ----- Platform Fees -----
PLATFORM_FEE_FIXED=0.50
PLATFORM_FEE_PERCENT=2.0
PLATFORM_CURRENCY=EUR

# ----- Security -----
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
CORS_ALLOWED_ORIGINS=https://ticketspace.es
TICKET_RESERVATION_TTL=900

# ----- File Uploads -----
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp
UPLOAD_PATH=uploads
